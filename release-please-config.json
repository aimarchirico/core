{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "separate-pull-requests": false,
  "packages": {
    "pnpm/packages/core-ts": {
      "release-type": "node"
    },
    "pnpm/packages/core-expo": {
      "release-type": "node"
    },
    "pnpm/packages/core-openapi": {
      "release-type": "node"
    },
    "pnpm/packages/core-tools": {
      "release-type": "node"
    },
    "pnpm/packages/core-docs": {
      "release-type": "node"
    },
    "gradle/security": {
      "release-type": "simple",
      "package-name": "core-security",
      "extra-files": ["build.gradle.kts"]
    },
    "gradle/test": {
      "release-type": "simple",
      "package-name": "core-test",
      "extra-files": ["build.gradle.kts"]
    },
    "gradle/build-logic": {
      "release-type": "simple",
      "package-name": "core-build-logic",
      "extra-files": ["build.gradle.kts"]
    }
  }
}
